@base = http://localhost:8092

###
POST {{base}}/api/guidance/sessions
Content-Type: application/json

{
  "userId": "user-101",
  "currentLocation": {
    "lat": 45.6579,
    "lng": 25.6012
  },
  "destination": {
    "lat": 45.6486,
    "lng": 25.6061
  },
  "thresholdDistanceMeters": 300,
  "thresholdEtaMinutes": 2,
  "speedKmh": 35
}

###
# Replace sessionId after creating a session.
GET {{base}}/api/guidance/sessions/{{sessionId}}

###
# Route-following location update.
POST {{base}}/api/guidance/sessions/{{sessionId}}/location
Content-Type: application/json

{
  "currentLocation": {
    "lat": 45.6550,
    "lng": 25.6025
  }
}

###
# Off-route update that should cause rerouting.
POST {{base}}/api/guidance/sessions/{{sessionId}}/location
Content-Type: application/json

{
  "currentLocation": {
    "lat": 45.6620,
    "lng": 25.6150
  }
}
